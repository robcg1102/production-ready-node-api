{
  "compilerOptions": {
    "target": "ES2023",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    
    "isolatedModules": true,

    "skipLibCheck": true,

    "ignoreDeprecations": "6.0",
     "types": ["jest","node"]
  },

  "include": ["src"]
}